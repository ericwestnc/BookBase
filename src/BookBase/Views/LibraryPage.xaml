<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BookBase.Models"
             x:Class="BookBase.Views.LibraryPage"
             Title="Library">
    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="8">
        <SearchBar Grid.Row="0" Placeholder="Search books" Text="{Binding SearchText}" SearchCommand="{Binding SearchCommand}" />
        <Button Grid.Row="1" Text="Toggle Grid/List" Command="{Binding ToggleViewCommand}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Books}" IsVisible="{Binding GridView}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <Frame Margin="4" CornerRadius="12" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Author}" FontSize="12" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Books}" IsVisible="{Binding GridView, Converter={StaticResource BoolInverseConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Edit" BackgroundColor="LightBlue" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid ColumnDefinitions="*,Auto" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding Author}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Status}" />
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
